{
  "package_version": 2,
  "name": "playable-ads-adapter",
  "description": "i18n:playable-ads-adapter.description",
  "main": "./main.js",
  "editor": ">=3.8.0",
  "author": "ppgee & yueby",
  "contributions": {
    "asset-db": {
      "mount": {
        "path": "./assets",
        "readonly": true
      }
    },
    "builder": "./main.js",
    "menu": [
      {
        "path": "i18n:menu.extension/",
        "label": "i18n:playable-ads-adapter.build",
        "message": "adapter-build"
      }
    ],
    "messages": {
      "adapter-build": {
        "methods": [
          "builder"
        ]
      },
      "update-language": {
        "methods": [
          "updateLanguage"
        ]
      },
      "query-build-state": {
        "methods": [
          "queryBuildState"
        ]
      },
      "cancel-build": {
        "methods": [
          "cancelBuild"
        ]
      }
    }
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "version": "2.0.3"
}